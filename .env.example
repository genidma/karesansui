# Copy to .env and fill in your key. .env is gitignored.
OPENROUTER_API_KEY=sk-or-...
# Optional: override the free model. MUST be one of the hardcoded FREE_MODELS
# list in src/llm.rs — anything else is rejected and falls back to the default.
# Allowed free models:
#   google/gemini-flash-8b:free
#   meta-llama/llama-3.1-8b-instruct:free
#   meta-llama/llama-3.2-3b-instruct:free
#   deepseek/deepseek-chat-v3-0324:free
#   qwen/qwen2.5-7b-instruct:free
#   microsoft/phi-3-mini-128k-instruct:free
OPENROUTER_MODEL=google/gemini-flash-8b:free
